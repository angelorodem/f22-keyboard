#include <freq.h>
#include <dt-bindings/zmk/hid_indicators.h>
#include <dt-bindings/zmk/matrix_transform.h>

#include "rp2354_split-layouts.dtsi"
#include "rp2354_split-pinctrl.dtsi"

&physical_layout0 {
    kscan = <&kscan0>;
    transform = <&matrix_transform0>;
};

/ {
    model = "F22 RP2354 Split";
    compatible = "f22,rp2354-split";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,flash-controller = &qmi;
        zephyr,code-partition = &code_partition;
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    aliases {
        led0 = &led0;
        watchdog0 = &wdt0;
    };

    leds {
        compatible = "gpio-leds";

        led0: caps_lock_led: led_0 {
            gpios = <&gpio0 31 GPIO_ACTIVE_HIGH>;
            label = "Caps Lock";
        };
    };

    wired_split {
        compatible = "zmk,wired-split";
        device = <&uart0>;
    };

    matrix_transform0: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)                         RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)                         RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(3,6) RC(2,7) RC(2,8) RC(2,9) RC(0,15) RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                 RC(3,7) RC(3,8)                         RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4)         RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10)                 RC(4,11) RC(4,12) RC(4,13) RC(4,14) RC(4,15)
        >;
    };
};

&flash0 {
    reg = <0x10000000 DT_SIZE_M(2)>;
    status = "okay";

    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        code_partition: partition@100 {
            label = "code";
            reg = <0x100 (DT_SIZE_M(2) - 0x100 - DT_SIZE_K(512))>;
        };

        storage_partition: partition@180000 {
            label = "storage";
            reg = <0x180000 DT_SIZE_K(512)>;
        };
    };
};

&uart0 {
    current-speed = <115200>;
    status = "okay";
    pinctrl-0 = <&uart0_default>;
    pinctrl-names = "default";
};

&gpio0 {
    status = "okay";
};

&timer0 {
    status = "okay";
};

&wdt0 {
    status = "okay";
};

zephyr_udc0: &usbd {
    status = "okay";
};
