menu "F22 debug probes"

config F22_DEBUG_PROBE
    bool "Enable F22 debug probes"
    default n

if F22_DEBUG_PROBE

config F22_DEBUG_PROBE_BLINK
    bool "Blink led0 from application context"
    depends on GPIO
    help
      Toggle the led0 alias from a kernel timer to confirm the system reaches
      application context without relying on USB bring-up.

config F22_DEBUG_PROBE_USB_STATE
    bool "Show USB device state on led0"
    depends on GPIO && USB_DEVICE_STACK
    help
      Drive the led0 alias with a repeating blink pattern after usb_enable().

config F22_DEBUG_PROBE_USB_ARMED
    bool "Link USB stack but never call usb_enable"
    depends on GPIO && USB_DEVICE_STACK
    help
      Pulls in the Zephyr USB device stack and the RP2350 USB driver so they
      are linked and statically initialized, but does not call usb_enable.
      Used to check whether merely linking USB code is enough to crash boot.

config F22_DEBUG_PROBE_USB_RAW
    bool "Call usb_enable from a thread after blinking"
    depends on GPIO && USB_DEVICE_STACK
    help
      Run from a kernel thread (not SYS_INIT) so the LED is guaranteed to
      blink before usb_enable is called. Useful to localize whether
      usb_enable itself faults.

config F22_DEBUG_PROBE_USB_INIT_BRACKET
    bool "Bracket USB controller init priority with led0"
    depends on GPIO && USB_DEVICE_STACK
    help
      Drives led0 off just before the default device init priority and on just
      after it. Used with a GPIO hog and application blink probe to determine
      whether boot stops inside the RP Pico USB controller init.

config F22_DEBUG_PROBE_USB_INIT_LADDER
    bool "Ladder of led0 pulse groups at increasing init priorities"
    depends on GPIO && USB_DEVICE_STACK
    help
      Registers SYS_INIT hooks at multiple POST_KERNEL and APPLICATION
      priorities. Each hook pulses led0 N times and leaves it on, where N
      matches the priority step. The last pulse group observed before the LED
      goes solid identifies the last priority reached before boot stalls.

config F22_DEBUG_PROBE_USB_APP_LADDER
    bool "Narrow led0 pulse ladder for application init priorities"
    depends on GPIO && USB_DEVICE_STACK
    help
      Registers SYS_INIT hooks after APPLICATION priority 50 and around the
      default application init priority. Used after the broad ladder shows boot
      reaches APPLICATION priority 50 but stalls before late application init.

config F22_DEBUG_PROBE_USB_ENABLE_GATE
    bool "Ladder through early USB enable with led0"
    depends on GPIO && USB_DEVICE_STACK
    help
      Replays the public, early steps of usb_enable() with a numbered LED
      pulse before each step. Used after controller attach succeeds to find
      which part of USB stack enable hangs before EP0 starts handling traffic.

endif

endmenu